    "##original code: https://dacon.io/competitions/official/236295/codeshare/11616?page=1&dtype=recent\n",
    "path = \"/home/yhkim/data/pdf_practice/train_source/\"         #pdf 파일이 있는 폴더 경로\n",
    "\n",
    "pdfs = [os.path.join(path, i) for i in os.listdir(path)]\n",
    "\n",
    "\n",
    "doc_texts = []\n",
    "for pdf_path in pdfs:\n",
    "    doc = fitz.open(pdf_path)\n",
    "    for page in doc:\n",
    "        text = page.get_text()\n",
    "    doc_texts.append(\n",
    "        Document(\n",
    "            page_content=text,\n",
    "            metadata={\"source\": pdf_path},\n",
    "        ))\n",
    "        \n",
    "        \n",
    "        # {pdf_path: text})"
   ]
  },
